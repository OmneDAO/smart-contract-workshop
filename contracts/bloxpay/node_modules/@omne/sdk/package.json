{
  "name": "@omne/sdk",
  "version": "1.1.0",
  "description": "Official TypeScript/JavaScript SDK for Omne Blockchain - Commerce-first blockchain with dual-layer consensus and microscopic fees",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.browser.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/index.browser.js",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "omne-sdk-verify-runtime": "dist/cli/verify-runtime.cjs"
  },
  "scripts": {
    "prebuild": "npm run sync:runtime-manifest",
    "build": "rollup -c",
    "postbuild": "node scripts/copy-runtime-manifest.js",
    "build:watch": "rollup -c -w",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docs": "typedoc src/index.ts",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "demo": "node examples/basic-usage.js",
    "sync:runtime-manifest": "node scripts/sync-runtime-manifest.js"
  },
  "keywords": [
    "omne",
    "blockchain",
    "cryptocurrency",
    "web3",
    "typescript",
    "javascript",
    "commerce",
    "micropayments",
    "dual-layer-consensus",
    "povera",
    "quar",
    "orc-20"
  ],
  "author": "OmneDAO <dev@omne.org>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OmneDAO/omne-blockchain.git",
    "directory": "sdk/typescript"
  },
  "bugs": {
    "url": "https://github.com/OmneDAO/omne-blockchain/issues"
  },
  "homepage": "https://omne.org",
  "dependencies": {
    "@noble/ciphers": "^2.0.1",
    "@noble/curves": "^1.9.0",
    "@noble/hashes": "^1.8.0",
    "@noble/secp256k1": "^2.3.0",
    "@scure/base": "^1.1.0",
    "@scure/bip32": "^1.4.0",
    "@scure/bip39": "^1.4.0",
    "aes-js": "^3.1.2",
    "big.js": "^6.2.1",
    "buffer": "^6.0.3"
  },
  "optionalDependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "node-fetch": "^3.3.2"
  },
  "peerDependenciesMeta": {
    "node-fetch": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-inject": "^5.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@types/big.js": "^6.2.2",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "express": "^4.22.1",
    "jest": "^29.7.0",
    "rimraf": "^5.0.7",
    "rollup": "^4.21.0",
    "rollup-plugin-commonjs": "^10.1.0",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "rollup-plugin-node-resolve": "^5.2.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.26.5",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
